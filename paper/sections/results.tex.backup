    \begin{axis}[
    width=0.88\textwidth,
    height=6cm,
    ybar,
    bar width=6pt,
    ymode=log,
    cycle list name=tensorstoreBarBW,
    ylabel={Cold load time (ms)},
    xlabel={Model},
